{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Groove Grammar Lab",
  "version": "1.0.0",
  "identifier": "ua.groovegrammarlab.app",
  "build": {
    "frontendDist": "../dist-web",
    "beforeBuildCommand": "node scripts/copy-web.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "Groove Grammar Lab",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "backgroundColor": "#101214"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "copyright": "Copyright © 2026",
    "category": "Music",
    "shortDescription": "Educational drum machine",
    "longDescription": "Phrase-aware educational drum machine: meter-aware generation, layered grooves, explanations, mixer, and MIDI/WAV export.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
